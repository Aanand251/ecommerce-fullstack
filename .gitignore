# ─── BACKEND (Spring Boot / Maven) ───────────────────
store/target/
store/.mvn/wrapper/maven-wrapper.jar
store/HELP.md
store/*.log
store/*.jar
store/*.war
store/*.ear
store/*.class

# Sensitive configuration
store/src/main/resources/application.properties

# ─── FRONTEND (Flutter) ──────────────────────────────
# Build artifacts
store_frontend/build/
store_frontend/.dart_tool/
store_frontend/.flutter-plugins
store_frontend/.flutter-plugins-dependencies
store_frontend/.packages
store_frontend/.pub-cache/
store_frontend/.pub/
store_frontend/pubspec.lock

# Generated files
store_frontend/**/*.g.dart
store_frontend/**/*.freezed.dart

